[*IF:ITEMTYPE|EQ|0] [*IF:SORTLEVEL|<|1] [*IF:TOTAL|>|0] [*ITEMKEYID,5,LEFT] [*ITEMDESCRIPTION,16,LEFT] [*QUANTITY,6,RIGHT,3] [*RETAILPRICE,6,RIGHT,2] [*TOTAL,7,RIGHT,2]





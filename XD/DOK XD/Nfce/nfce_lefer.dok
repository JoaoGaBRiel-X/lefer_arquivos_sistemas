<<! ############# Layout Editado por João Gabriel Carvalho - Lefer Automacao Comercial
<<! ############# Data: 03/01/2026
<<! ############# Inf: Mostra informacao de subtotal. Oculta campos do NFCE para impressao de documentos diferentes de '1', atualizado reforma tributaria
<<! ###################################################################################################################
<<! #################################################################### LICENCE SECTION (Editable inside the software)
<<! ###################################################################################################################
[$BUSINESS_DATA_GLOBAL]
<<! ###################################################################################################################
<<! ########################################################################################### DOCUMENT NUMBER SECTION
<<! ###################################################################################################################

[$DOCUMENTID]
[$COPYINFO]

<<! ###################################################################################################################
<<! ############################################################################################### CLIENT DATA SECTION
<<! ###################################################################################################################
<<!  #### FONTSIZE SETUP FOR THIS SECTION
<<IF=[$PRINTERTYPE]|EQ|G>>
<<!  ############################## GRAPHIC MODE PRINTER
<<FONTSIZE=8>>
<<FONTNAME=Courier New>>
<<FONTBOLD=TRUE>>
<<ELSE>>
<<!  ############################## DIRECT MODE PRINTER
<<ESCAPE=ESC ! D>>
<<ENDIF>>
<<! ############################### REMOVE NAME TITLE 
<<SET=[$NAMETITLE],[$TRANSLATE:20001]:>>
<<IF=[$INVOICETYPE]|EQ|FS>>
<<SET=[$NAMETITLE],>>
<<ENDIF>>
<<IF=[$ENTITYVAT]|<>|999999990>>
<<! ###################################### NAME AND VAT NUMBER (IF CLIENT WAS SELECTED)
[$NAMETITLE] [$ENTITYDESCRIPTION]
[$TRANSLATE:20002]: [$ENTITYVAT]
<<ELSE>>
<<!  ######################################################## IF NO CLIENT CHOSEN THEN:
[$TRANSLATE:20002]: [$ENTITYDESCRIPTION]
<<ENDIF>>
<<!  ############################################################ OTHER CLIENT DETAILS
<<IF=[$ENTITYADDRESS]|<>|>>
[$ENTITYADDRESS]
<<ENDIF>>
<<IF=[$ENTITYPOSTALCODE]|<>|>>
[$ENTITYPOSTALCODE]
<<ENDIF>>
<<IF=[$ENTITYCITY]|<>|>>
[$ENTITYCITY]
<<ENDIF>>
<<IF=[$ENTITYSTATE]|<>|>>
[$ENTITYSTATE]
<<ENDIF>>
<<! ###################### Next line fields: TaxPointDate
<<IF=[$TAXPOINTDATE]|<>|>>
[$TAXPOINTDATE]
<<ENDIF>>
<<! ###################################################################################################################
<<! ################################################################################## PRODUCT LINE SECTION STARTS HERE
<<! ###################################################################################################################
<<!
<<! ##################################################################################
<<! ############################# PRODUCT LINES FOR GRAPHIC MODE PRINTER (O.S. Driver)
<<! ##################################################################################

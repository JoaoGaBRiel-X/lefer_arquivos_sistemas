{"Guid":"707d9a7d-5ac1-4270-986b-e75e7b25a4a2","Name":"Vendas por F Pagamento","Description":"Vendas por F Pagamento","SqlQuery":"SELECT\r\nDATE_FORMAT(dh.CloseDate,'%d/%m/%Y') AS 'Data Fechamento',\r\nDATE_FORMAT(dh.CloseDate,'%H:%i:%s') AS 'Hora Fechamento',\r\nCONCAT(dh.DocumentKeyId, ' ', dh.SerieId, '/', dh.Number) AS \"Documento\",\r\ndh.SaleZoneAreaObjectId as \"Mesa\",\r\nCONCAT(\"Terminal\",' ',dh.Terminal) AS \"Terminais\",\r\nus.Name AS \"Funcionário de Fechamento\",\r\ncp.Id AS \"ID F/ Pagamento\",\r\ncp.Description as \"Forma de pagamento\",\r\nround(SUM(dh.total+dh.TotalDiscounts),2) as \"Subtotal\",\r\nround(dh.TotalDiscounts,2) as \"Desconto\",\r\nround(dh.TotalServiceTax,2) AS \"Taxa de Serviço\",\r\n    SUM(\r\n        CASE\r\n            WHEN cdh.CashierFlow = 1 THEN ROUND(ip.Total, 2)\r\n            WHEN cdh.CashierFlow = 2 THEN -1 * ROUND(ip.Total, 2)\r\n            ELSE 0.0\r\n        END\r\n    ) AS \"Total\"\r\nFROM\r\n    invoicepaymentdetails ip \r\nLEFT JOIN\r\n    xconfigpaymenttypes cp ON ip.PaymentTypeId = cp.Id\r\nLEFT JOIN\r\n    documentsheaders dh ON dh.Number = ip.InvoiceNumber AND dh.SerieId = ip.SerieId AND dh.DocumentTypeId = ip.DocumentTypeId\r\nLEFT JOIN\r\n    xconfigdocumentstypes cdh ON ip.DocumentTypeId = cdh.Id\r\nINNER JOIN \r\n\t users us ON dh.CloseUserId = us.Id    \r\nWHERE\r\n    cdh.CashierFlow IN (1, 2) AND dh.CloseDate >= @p_Data_Inicial AND dh.CloseDate <= DATE_ADD(@p_Data_Final, INTERVAL 1 DAY)\r\nGROUP BY\r\n    ip.PaymentTypeId, cp.Description, dh.Number\r\nORDER BY dh.Number; @WHERE  @OTHERS ","SqlQueryWhere":"","SqlOtherClauses":"","Parameters":[{"Name":"@p_Data_Inicial","ParameterType":"XDPeople.Framework.Date, XDPeople.NET, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null","DefaultValueType":0,"AvailableValueType":0,"AvailableValuesList":[]},{"Name":"@p_Data_Final","ParameterType":"XDPeople.Framework.Date, XDPeople.NET, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null","DefaultValueType":0,"AvailableValueType":0,"AvailableValuesList":[]}],"Fields":[{"Name":"Data Fechamento","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Hora Fechamento","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Documento","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Mesa","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Terminais","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Funcionário de Fechamento","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"ID F/ Pagamento","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Forma de pagamento","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Subtotal","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"Formatting":" \\R$ ###,###,###,##0.00","IsVisible":true},{"Name":"Desconto","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"Formatting":" \\R$ ###,###,###,##0.00","IsVisible":true},{"Name":"Taxa de Serviço","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"Formatting":" \\R$ ###,###,###,##0.00","IsVisible":true},{"Name":"Total","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"Formatting":" \\R$ ###,###,###,##0.00","IsVisible":true}],"IsPivot":false,"ExternalConnection":"","AddToRibbon":true,"ShowInPos":true}
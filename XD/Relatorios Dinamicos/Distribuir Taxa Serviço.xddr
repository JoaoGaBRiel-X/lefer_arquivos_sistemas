{"Guid":"17b95619-44b7-4a8f-a924-5a24265e1847","Name":"Distribuir Taxa Serviço","Description":"Distribuir Taxa Serviço","SqlQuery":"SELECT Terminal,\r\nSaleZoneAreaObjectId AS 'Mesa',\r\nusers.Name AS 'Funcionário',\r\nEntityDescription AS 'Cliente',\r\nRound(Total + TotalServiceTax, 2) AS 'Total C/ Serviço',\r\nRound(Total, 2) AS 'Total S/ Serviço',\r\nRound(TotalServiceTax, 2) AS 'Taxa de Serviço',\r\nDocumentKeyId AS 'Documento',\r\nRound((TotalServiceTax * (@p_Porcent_Garçom / 100)), 2) AS 'Taxa ao Garçom',\r\nRound((TotalServiceTax * (@p_Porcent_Cozinha / 100)), 2) AS 'Taxa para Cozinha',\r\nDATE_FORMAT(CreationDate, '%d/%m/%Y') AS 'Data Criação',\r\nDATE_FORMAT(CloseDate, '%d/%m/%Y') AS 'Data de Fechamento',\r\nDATE_FORMAT(CreationDate, '%h:%i') AS 'Horário Criação',\r\nDATE_FORMAT(CloseDate, '%h:%i') AS 'Horário de Fechamento'\r\nFROM documentsheaders \r\nJOIN users ON users.Id = documentsheaders.CreationUserId\r\nJOIN xconfigpaymenttypes ON xconfigpaymenttypes.Id = PaymentType\r\nGROUP BY documentsheaders.Id\r\nOrder by documentsheaders.CloseDate; @WHERE  @OTHERS ","SqlQueryWhere":"","SqlOtherClauses":"","Parameters":[{"Name":"@p_Porcent_Garçom","ParameterType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","DefaultValueType":0,"AvailableValueType":0,"AvailableValuesList":[]},{"Name":"@p_Porcent_Cozinha","ParameterType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","DefaultValueType":0,"AvailableValueType":0,"AvailableValuesList":[]}],"Fields":[{"Name":"Terminal","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Mesa","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Funcionário","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Cliente","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Total C/ Serviço","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Total S/ Serviço","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Taxa de Serviço","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Documento","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Taxa ao Garçom","FieldType":"System.Double, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Taxa para Cozinha","FieldType":"System.Double, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Data Criação","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Data de Fechamento","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Horário Criação","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Horário de Fechamento","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true}],"IsPivot":false,"ExternalConnection":"","AddToRibbon":true,"ShowInPos":true}
{"Guid":"d75be463-5b18-4659-b373-0443aa3ac462","Name":"Total por dia","Description":"Total por dia","SqlQuery":"/*\r\nRelatorio: Total por Dia\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 27/03/2023\r\nATUALIZADO: 27/03/2023\r\n*/\r\nSELECT\r\nDATE_FORMAT(dh.CloseDate,'%d/%m/%Y') AS 'Data Fecham',\r\nSUM(round(dh.total, 2)) AS 'Subtotal',\r\nSUM(round(dh.totaldiscounts, 2)) AS 'Desconto',\r\nSUM(round(dh.totalservicetax, 2)) AS 'Taxa Serviço',\r\nSUM(round(dh.paidamount, 2)) AS 'Total Pago'\r\nFROM documentsheaders AS dh\r\n/*\r\nRelatorio: Total por Dia\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 27/03/2023\r\nATUALIZADO: 27/03/2023\r\n*/ @WHERE  @OTHERS ","SqlQueryWhere":"WHERE DATE(dh.CloseDate) BETWEEN @p_data1 AND @p_data2","SqlOtherClauses":"GROUP BY DATE_FORMAT(dh.CloseDate,'%d/%m/%Y')\r\nORDER BY dh.CloseDate","Parameters":[{"Name":"@p_data1","Caption":"Data Inicial","ParameterType":"XDPeople.Framework.Date, XDPeople.NET, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null","DefaultValue":10,"DefaultValueType":2,"AvailableValueType":0,"AvailableValuesList":[]},{"Name":"@p_data2","Caption":"Data Final","ParameterType":"XDPeople.Framework.Date, XDPeople.NET, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null","DefaultValue":11,"DefaultValueType":2,"AvailableValueType":0,"AvailableValuesList":[]}],"Fields":[{"Name":"Data Fecham","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Subtotal","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Desconto","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Taxa Serviço","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Total Pago","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true}],"IsPivot":false,"ExternalConnection":"","AddToRibbon":true,"ShowInPos":true}
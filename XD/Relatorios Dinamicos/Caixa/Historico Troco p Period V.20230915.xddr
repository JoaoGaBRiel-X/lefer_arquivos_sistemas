{"Guid":"236f7903-35e8-47d3-b9df-d45a72b09b11","Name":"Historico Troco p/ Period","Description":"Hist troco periodo","SqlQuery":"/*\r\nRelatorio: Historico Troco p/ Period\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 07/08/2023\r\nATUALIZADO: 15/09/2023\r\n*/\r\nselect\r\ndh.terminal as 'Terminal',\r\ndh.Number as 'Documento',\r\ndh.CloseDate as 'Data',\r\ndh.SaleZoneAreaObjectId as 'Mesa/Comanda',\r\ndh.EntityDescription as 'Cliente',\r\nRound(dh.paidamount, 2) as 'Total',\r\nRound(t.`entregue`, 2) as 'Entregue',\r\nRound(t.`troco`, 2) as 'Troco'\r\nfrom documentsheaders dh\r\ninner join (select \r\n\tentregue.invoicenumber as 'number', \r\n\tentregue.total as 'entregue', \r\n\ttroco.total as 'troco',\r\n\tentregue.SerieId as 'SerieId',\r\n\tentregue.DocumentTypeId as 'DocumentTypeId',\r\n\tentregue.PaymentTypeId as 'PaymentTypeId'\r\nfrom (select * from invoicepaymentdetails where Ischange = 0 and PaymentTypeId = 1) as entregue\r\ninner join (select * from invoicepaymentdetails where Ischange = 1 and PaymentTypeId = 1) as troco on troco.invoicenumber = entregue.invoicenumber and troco.Id = entregue.Id + 1) t\r\non dh.Number = t.`number`\r\n/*\r\nRelatorio: Historico Troco p/ Period\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 07/08/2023\r\nATUALIZADO: 15/09/2023\r\n*/ @WHERE  @OTHERS ","SqlQueryWhere":"where DATE(dh.CloseDate) between @p_DataInicial and @p_DataFinal and t.SerieId = dh.SerieId and t.DocumentTypeId = dh.DocumentTypeId and t.PaymentTypeId = dh.PaymentType","SqlOtherClauses":"order by dh.terminal, dh.Number desc","Parameters":[{"Name":"@p_DataInicial","Caption":"Data Inicial","ParameterType":"XDPeople.Framework.Date, XDPeople.NET, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null","DefaultValue":2,"DefaultValueType":2,"AvailableValueType":0,"AvailableValuesList":[]},{"Name":"@p_DataFinal","Caption":"Data Final","ParameterType":"XDPeople.Framework.Date, XDPeople.NET, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null","DefaultValue":2,"DefaultValueType":2,"AvailableValueType":0,"AvailableValuesList":[]}],"Fields":[{"Name":"Terminal","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Documento","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Mesa/Comanda","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Cliente","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Total","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Entregue","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Troco","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Data","FieldType":"System.DateTime, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true}],"IsPivot":false,"ExternalConnection":"","AddToRibbon":true,"ShowInPos":true}
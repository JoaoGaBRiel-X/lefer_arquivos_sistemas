{"Guid":"3c5e4f1d-ad7c-4228-8f3c-af5ad1a7ed38","Name":"Total F.Pagamento Turno","Description":"T. F.Pag Turno","SqlQuery":"/*\r\nRelatorio: Total F.Pagamento Turno\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 13/01/2023\r\nATUALIZADO: 13/01/2023\r\n*/\r\nselect \r\ndh.shift as 'Turno',\r\ndh.numdoccx as 'Sessão Caixa',\r\ndh.closedate as 'Data',\r\npt.Description as 'Formapagamento',\r\nsum(round(ipd.Total, 2)) as 'Total'\r\nfrom invoicepaymentdetails as ipd\r\ninner join documentsheaders as dh\r\non ipd.InvoiceNumber = dh.Number\r\ninner join xconfigpaymenttypes as pt\r\non ipd.PaymentTypeId = pt.Id\r\n/*\r\nRelatorio: Total F.Pagamento Turno\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 13/01/2023\r\nATUALIZADO: 13/01/2023\r\n*/ @WHERE  @OTHERS ","SqlQueryWhere":"where date(dh.closedate) = @p_data","SqlOtherClauses":"group by dh.shift, dh.numdoccx, ipd.paymenttypeid","Parameters":[{"Name":"@p_data","Caption":"Data","ParameterType":"XDPeople.Framework.Date, XDPeople.NET, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null","DefaultValueType":0,"AvailableValueType":0,"AvailableValuesList":[]}],"Fields":[{"Name":"Turno","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Sessão Caixa","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Data","FieldType":"System.DateTime, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"Formatting":"d","IsVisible":true},{"Name":"Formapagamento","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Total","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"Formatting":" \\R$ ###,###,###,##0.00","IsVisible":true}],"IsPivot":false,"ExternalConnection":"","AddToRibbon":true,"ShowInPos":true}
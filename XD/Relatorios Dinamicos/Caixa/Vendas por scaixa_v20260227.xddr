{"Guid":"8f8131ba-d922-4137-afce-287c2fa53538","Name":"Vendas por scaixa","Description":"Vendas por sessão de caixa","SqlQuery":"SELECT\r\n\tdh.terminal as 'Terminal',\r\n\tCONCAT(dh.DocumentKeyId, \" \", dh.SerieId, \"/\", dh.Number) as \"Documento\",\r\n\tdh.shift as 'Turno',\r\n\t    CASE \r\n        WHEN dh.SaleZoneAreaObjectId > 999999 THEN 'Delivery'\r\n        ELSE dh.SaleZoneAreaObjectId \r\n    END AS \"Comanda/Mesa\",\r\n\tDATE_FORMAT(dh.CloseDate,'%d/%m/%Y') as 'Data Fecham',\r\n\tDATE_FORMAT(dh.CloseDate,'%H:%i:%s') as 'Hora Fecham',\r\n\tu.Name as 'Operador',\r\n\tround(dh.total, 2) as 'Subtotal',\r\n\tround(dh.totaldiscounts, 2) as 'Desconto',\r\n\tround(dh.totalservicetax, 2) as 'Taxa Serviço',\r\n\tround(dh.paidamount, 2) as 'Total Pago'\r\n\r\nFROM \r\n\tbusinessaccountledger b \r\nINNER JOIN \r\n\tcashieraccountsession c ON c.Id = @p_SCaixa\r\nINNER JOIN \r\n\tdocumentsheaders dh ON b.DocumentGuid = dh.Guid\r\ninner JOIN \r\n\tusers AS u ON dh.closeuserid = u.id\r\nWHERE \r\n\tb.CreationDate BETWEEN c.StartDate AND c.EndDate AND b.BusinessAccountId = c.CashierAccountId AND b.MovementType = 5 @WHERE  @OTHERS ","SqlQueryWhere":"","SqlOtherClauses":"","Parameters":[{"Name":"@p_SCaixa","ParameterType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Query":"SELECT \r\nc.Id AS \"Sessão do Caixa\"\r\nFROM cashieraccountsession c\r\nWHERE c.EndDate IS NOT NULL\r\nORDER BY c.Id\r\n","DefaultValueType":0,"AvailableValueType":2,"AvailableValuesList":[]}],"Fields":[{"Name":"Terminal","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Documento","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Turno","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Comanda/Mesa","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Data Fecham","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Hora Fecham","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Operador","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Subtotal","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"Formatting":" \\R$ ###,###,###,##0.00","IsVisible":true},{"Name":"Desconto","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"Formatting":" \\R$ ###,###,###,##0.00","IsVisible":true},{"Name":"Taxa Serviço","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"Formatting":" \\R$ ###,###,###,##0.00","IsVisible":true},{"Name":"Total Pago","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"Formatting":" \\R$ ###,###,###,##0.00","IsVisible":true}],"IsPivot":false,"ExternalConnection":"","AddToRibbon":true,"ShowInPos":true}
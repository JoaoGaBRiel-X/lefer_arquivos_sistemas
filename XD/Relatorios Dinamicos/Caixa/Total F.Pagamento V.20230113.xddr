{"Guid":"624b07c1-3b1d-4f57-b08e-9b84d356053e","Name":"Total F.Pagamento","Description":"T. F.Pagamento","SqlQuery":"/*\r\nRelatorio: Total F.Pagamento\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 13/01/2023\r\nATUALIZADO: 13/01/2023\r\n*/\r\nselect \r\ndh.closedate as 'Data',\r\npt.Description as 'Formapagamento',\r\nsum(round(ipd.total, 2)) as 'Total'\r\nfrom invoicepaymentdetails as ipd\r\ninner join documentsheaders as dh\r\non ipd.InvoiceNumber = dh.Number\r\ninner join xconfigpaymenttypes as pt\r\non ipd.PaymentTypeId = pt.Id\r\n/*\r\nRelatorio: Total F.Pagamento\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 13/01/2023\r\nATUALIZADO: 13/01/2023\r\n*/ @WHERE  @OTHERS ","SqlQueryWhere":"where date(dh.closedate) = @p_data","SqlOtherClauses":"group by ipd.paymenttypeid","Parameters":[{"Name":"@p_data","Caption":"Data","ParameterType":"XDPeople.Framework.Date, XDPeople.NET, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null","DefaultValueType":0,"AvailableValueType":0,"AvailableValuesList":[]}],"Fields":[{"Name":"Data","FieldType":"System.DateTime, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"Formatting":"d","IsVisible":true},{"Name":"Formapagamento","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Total","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"Formatting":" \\R$ ###,###,###,##0.00","IsVisible":true}],"IsPivot":false,"ExternalConnection":"","AddToRibbon":true,"ShowInPos":true}
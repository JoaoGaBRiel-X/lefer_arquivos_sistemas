{"Guid":"e384e26e-6ec7-4328-b979-3853bfc090c2","Name":"Movimento Caixa p/ Dia","Description":"Mov Cx Dia","SqlQuery":"/*\r\nRelatorio: Movimento Caixa p/ Dia\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 07/08/2023\r\nATUALIZADO: 07/08/2023\r\n*/\r\nselect \r\nc.CXMovNDOCCX as 'Sessao CX',\r\nc.CXMovTerminal as 'Terminal',\r\nu.Name as 'Usuario',\r\ncase\r\n\twhen c.CXMovTypeID = 1 then 'Abertura'\r\n\twhen c.CXMovTypeID = 2 then 'Entrada'\r\n\twhen c.CXMovTypeID = 3 then 'Saída'\r\n\twhen c.CXMovTypeID = 4 then 'Sangria'\r\n\twhen c.CXMovTypeID = 5 then 'Tipo Pagamento'\r\n\twhen c.CXMovTypeID = 6 then 'Informado'\r\nend as 'Tipo',\r\nc.CXMovObs as 'Descricao',\r\nCAST(c.CXMovValue AS DECIMAL(18,2)) as 'Valor'\r\nfrom cxmov c\r\ninner join users u on c.CXMovUser = u.Id\r\n/*\r\nRelatorio: Movimento Caixa p/ Dia\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 07/08/2023\r\nATUALIZADO: 07/08/2023\r\n*/ @WHERE  @OTHERS ","SqlQueryWhere":"where cxmovdate = @p_Data","SqlOtherClauses":"order by c.CXMovNDOCCX, c.PaymentId","Parameters":[{"Name":"@p_Data","Caption":"Data","ParameterType":"XDPeople.Framework.Date, XDPeople.NET, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null","DefaultValue":2,"DefaultValueType":2,"AvailableValueType":0,"AvailableValuesList":[]}],"Fields":[{"Name":"Sessao CX","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Terminal","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Usuario","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Tipo","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Descricao","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Valor","FieldType":"System.Double, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true}],"IsPivot":false,"ExternalConnection":"","AddToRibbon":true,"ShowInPos":true}
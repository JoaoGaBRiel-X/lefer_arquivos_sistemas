{"Guid":"e2169c37-0010-43a7-9248-504d2918fa51","Name":"Informação Sessão Caixa","Description":"Informação Sessão Caixa","SqlQuery":"/*\r\nRelatorio: Informação Sessão Caixa\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 10/12/2021\r\n*/\r\nselect\r\ncft.id as 'Terminal',\r\ncft.description as 'Descrição',\r\nconvert(cft.numdoccx, char) as 'S Caixa Atual',\r\nCASE WHEN EXISTS \r\n(SELECT * FROM(select * from documentsheaders\r\nunion all\r\nselect * from docheaderscanceled) as dh\r\nWHERE (cft.id = dh.terminal && dh.NumDocCX = cft.numdoccx)\r\n)\r\nTHEN 'Sim'\r\nELSE 'Não' \r\nEND as 'Sessão atual com movimento?'\r\nfrom xconfigterminals as cft\r\n\r\n/*\r\nRelatorio: Informação Sessão Caixa\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 10/12/2021\r\n*/\r\n @WHERE  @OTHERS ","SqlQueryWhere":"","SqlOtherClauses":"","Parameters":[],"Fields":[{"Name":"Terminal","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Descrição","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"S Caixa Atual","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Sessão atual com movimento?","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true}],"IsPivot":false,"ExternalConnection":"","AddToRibbon":true,"ShowInPos":true}
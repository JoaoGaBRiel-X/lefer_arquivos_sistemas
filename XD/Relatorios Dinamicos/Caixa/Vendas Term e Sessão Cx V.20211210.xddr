{"Guid":"56cc4fb1-9893-4e2d-bdff-49f7fcda9244","Name":"Vendas p/Term e Sessão Cx","Description":"V Term e Sessao","SqlQuery":"/*\r\nRelatorio: Vendas p/Term e Sessão Cx\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 10/12/2021\r\n*/\r\nselect\r\ndh.Number as 'Numero',\r\ndh.serieid as 'Serie',\r\ndh.documentkeyid as 'Tipo Doc',\r\ndh.terminal as 'Terminal',\r\ndh.NumDocCX as 'Sessão Caixa',\r\ndh.shift as 'Turno',\r\ndh.saleZoneAreaObjectId as 'Comanda/Mesa',\r\nDATE_FORMAT(dh.CloseDate,'%d/%m/%Y') as 'Data Fecham',\r\nDATE_FORMAT(dh.CloseDate,'%H:%i:%s') as 'Hora Fecham',\r\nu.Name as 'Operador',\r\nround(dh.total, 2) as 'Subtotal',\r\nround(dh.totaldiscounts, 2) as 'Desconto',\r\nround(dh.totalservicetax, 2) as 'Taxa Serviço',\r\nround(dh.paidamount, 2) as 'Total Pago',\r\ncase \r\nwhen dh.deleted = 0 then 'Não'\r\nwhen dh.deleted = 1 then 'Sim' \r\nend as 'Cancelado'\r\nfrom(select * from documentsheaders\r\nunion all\r\nselect * from docheaderscanceled) as dh\r\ninner join users as u\r\non dh.closeuserid = u.id\r\n/*\r\nRelatorio: Vendas p/Term e Sessão Cx\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 10/12/2021\r\n*/ @WHERE  @OTHERS ","SqlQueryWhere":"where dh.terminal = @p_terminal and dh.NumDocCX = @p_sessaocx","SqlOtherClauses":"order by dh.Number","Parameters":[{"Name":"@p_terminal","Caption":"Terminal","ParameterType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","DefaultValue":1,"DefaultValueType":1,"AvailableValueType":1,"AvailableValuesList":[{"Description":"Terminal 1","Value":1},{"Description":"Terminal 2","Value":2},{"Description":"Terminal 3","Value":3},{"Description":"Terminal 4","Value":4},{"Description":"Terminal 5","Value":5},{"Description":"Terminal 6","Value":6},{"Description":"Terminal 7","Value":7},{"Description":"Terminal 8","Value":8},{"Description":"Terminal 9","Value":9},{"Description":"Terminal 10","Value":10},{"Description":"Terminal 11","Value":11},{"Description":"Terminal 12","Value":12},{"Description":"Terminal 13","Value":13},{"Description":"Terminal 14","Value":14},{"Description":"Terminal 15","Value":15},{"Description":"Terminal 16","Value":16},{"Description":"Terminal 17","Value":17},{"Description":"Terminal 18","Value":18},{"Description":"Terminal 19","Value":19},{"Description":"Terminal 20","Value":20},{"Description":"Terminal 21","Value":21},{"Description":"Terminal 22","Value":22},{"Description":"Terminal 23","Value":23},{"Description":"Terminal 24","Value":24},{"Description":"Terminal 25","Value":25}]},{"Name":"@p_sessaocx","Caption":"Sessão Caixa","ParameterType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","DefaultValueType":0,"AvailableValueType":0,"AvailableValuesList":[]}],"Fields":[{"Name":"Numero","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Serie","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Tipo Doc","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Terminal","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Sessão Caixa","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Turno","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Comanda/Mesa","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Data Fecham","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Hora Fecham","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Operador","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Subtotal","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Desconto","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Taxa Serviço","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Total Pago","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Cancelado","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true}],"IsPivot":false,"ExternalConnection":"","AddToRibbon":true,"ShowInPos":true}
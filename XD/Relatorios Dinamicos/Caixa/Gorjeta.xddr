{"Guid":"18595178-cc81-4088-9858-965655f712aa","Name":"Gorjeta","Description":"Gorjeta por funcionário","SqlQuery":"SELECT users.Name AS 'Funcionário',\r\ndocumentsheaders.SaleZoneAreaObjectId AS 'Mesa',\r\ndocumentsheaders.Terminal AS 'Terminal',\r\nDATE_FORMAT(documentsheaders.CreationDate, '%d/%m/%Y %H:%i') AS 'Hora_Lançamento',\r\nDATE_FORMAT(documentsheaders.CloseDate, '%d/%m/%Y %H:%i') AS 'Hora_Fechamento',\r\ndocumentsheaders.DocumentKeyId AS 'Tipo de Documento',\r\nxconfigpaymenttypes.Description AS 'Tipo de Pagamento',\r\nround(documentsheaders.Total, 2) AS 'Valor S/T Serviço',\r\nround(documentsheaders.PaidAmount, 2) AS 'Valor C/T Serviço',\r\nround(invoicepaymentdetails.TipValue, 2)  AS 'Gorjeta'\r\nFROM invoicepaymentdetails \r\nJOIN documentsheaders ON invoicepaymentdetails.InvoiceNumber = documentsheaders.Number\r\nJOIN users ON documentsheaders.CloseUserId = users.Id\r\nJOIN xconfigpaymenttypes ON invoicepaymentdetails.DocumentTypeId = xconfigpaymenttypes.Id \r\nWHERE invoicepaymentdetails.Total > 0 \r\nAND invoicepaymentdetails.TipValue <> 0\r\nAND @p_Cod_Funcionário = users.Id\r\nAND DATE_FORMAT(documentsheaders.CreationDate, '%d/%m/%Y') BETWEEN DATE_FORMAT(@p_Data_Inicial, '%d/%m/%Y') AND DATE_FORMAT(@p_Data_Final, '%d/%m/%Y') @WHERE  @OTHERS ","SqlQueryWhere":"","SqlOtherClauses":"","Parameters":[{"Name":"@p_Cod_Funcionário","Caption":"Funcionário","ParameterType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","EntityType":"XDPeople.Entities.UserBE, XDPeople.NET, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null","DefaultValueType":0,"AvailableValueType":0,"AvailableValuesList":[]},{"Name":"@p_Data_Inicial","Caption":"Data Inicial","ParameterType":"XDPeople.Framework.Date, XDPeople.NET, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null","DefaultValueType":0,"AvailableValueType":0,"AvailableValuesList":[]},{"Name":"@p_Data_Final","Caption":"Data Final","ParameterType":"XDPeople.Framework.Date, XDPeople.NET, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null","DefaultValueType":0,"AvailableValueType":0,"AvailableValuesList":[]}],"Fields":[{"Name":"Funcionário","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Mesa","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Terminal","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Hora_Lançamento","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Hora_Fechamento","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Tipo de Documento","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Tipo de Pagamento","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Valor S/T Serviço","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Valor C/T Serviço","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Gorjeta","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true}],"IsPivot":false,"ExternalConnection":"","AddToRibbon":true,"ShowInPos":true}
{"Guid":"049c6259-4d50-4d1a-815b-7c61e42765e8","Name":"Faturas Det Pag p/ Data","Description":"F D Pag p Data","SqlQuery":"/*\r\nRelatorio: Faturas Det Pag p/ Data\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 13/01/2023\r\nATUALIZADO: 15/09/2023\r\n*/\r\nSELECT\r\n\tdh.documentkeyid AS 'Tipo Doc',\r\n\tdh.Number AS 'Numero',\r\n\tdh.serieid AS 'Serie',\r\n\tdh.terminal AS 'Terminal',\r\n\tdh.NumDocCX AS 'Sessão Caixa',\r\n\tdh.shift AS 'Turno',\r\n\tdh.saleZoneAreaObjectId AS 'Comanda/Mesa',\r\n\tdh.entitydescription AS 'Cliente',\r\n\tDATE_FORMAT(dh.CloseDate,'%d/%m/%Y') AS 'Data Fecham',\r\n\tDATE_FORMAT(dh.CloseDate,'%H:%i:%s') AS 'Hora Fecham',\r\n\tu.Name AS 'Operador',\r\n\tround(dh.total, 2) AS 'Subtotal',\r\n\tround(dh.totaldiscounts, 2) AS 'Desconto',\r\n\tround(dh.totalservicetax, 2) AS 'Taxa Serviço',\r\n\tround(dh.paidamount, 2) AS 'Total',\r\n\tround(ipd.total, 2) AS 'Valor Pago',\r\n\tpt.Description as 'F Pagamento',\r\n\tCASE \r\n\tWHEN dh.deleted = 0 THEN 'Não'\r\n\tWHEN dh.deleted = 1 THEN 'Sim' \r\n\tEND AS 'Cancelado'\r\nFROM invoicepaymentdetails AS ipd\r\nINNER JOIN (SELECT * FROM documentsheaders\r\n\t\t\tUNION ALL\r\n\t\t\tSELECT * FROM docheaderscanceled) AS dh\r\nON ipd.InvoiceNumber = dh.Number\r\nINNER JOIN users AS u\r\nON dh.closeuserid = u.id\r\nINNER JOIN xconfigpaymenttypes AS pt\r\nON ipd.PaymentTypeId = pt.Id\r\n/*\r\nRelatorio: Faturas Det Pag p/ Data\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 13/01/2023\r\nATUALIZADO: 15/09/2023\r\n*/ @WHERE  @OTHERS ","SqlQueryWhere":"WHERE DATE(dh.CloseDate) BETWEEN @p_data1 AND @p_data2 and ipd.SerieId = dh.SerieId and ipd.InvoiceNumber = dh.number and ipd.DocumentTypeId = dh.DocumentTypeId","SqlOtherClauses":"ORDER BY dh.Number","Parameters":[{"Name":"@p_data1","Caption":"Data Inicial","ParameterType":"XDPeople.Framework.Date, XDPeople.NET, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null","DefaultValue":12,"DefaultValueType":2,"AvailableValueType":0,"AvailableValuesList":[]},{"Name":"@p_data2","Caption":"Data Final","ParameterType":"XDPeople.Framework.Date, XDPeople.NET, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null","DefaultValue":2,"DefaultValueType":2,"AvailableValueType":0,"AvailableValuesList":[]}],"Fields":[{"Name":"Tipo Doc","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Numero","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Serie","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Terminal","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Sessão Caixa","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Turno","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Comanda/Mesa","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Cliente","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Data Fecham","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Hora Fecham","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Operador","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Subtotal","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Desconto","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Taxa Serviço","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Total","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Valor Pago","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"F Pagamento","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Cancelado","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true}],"IsPivot":false,"ExternalConnection":"","AddToRibbon":true,"ShowInPos":true}
{"Guid":"27527a32-4ff0-4358-ba6f-4fbb0be815cc","Name":"Vendas Delivery p/ Data","Description":"Vendas Delivery","SqlQuery":"/*\r\nRelatorio: Vendas Delivery p/Data\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 26/05/2022\r\nATUALIZADO: 24/11/2022\r\n*/\r\nSELECT\r\ndh.Number AS 'Numero',\r\ndh.serieid AS 'Serie',\r\ndh.documentkeyid AS 'Tipo Doc',\r\ndh.terminal AS 'Terminal',\r\ndh.NumDocCX AS 'Sessão Caixa',\r\ndh.shift AS 'Turno',\r\ndh.saleZoneAreaObjectId AS 'Num Delivery',\r\ndh.entitykeyid AS 'Cod Cliente',\r\ndh.entitydescription as 'Cliente',\r\nDATE_FORMAT(dh.CloseDate,'%d/%m/%Y') AS 'Data Entrega',\r\nDATE_FORMAT(dh.CloseDate,'%H:%i:%s') AS 'Hora Entrega',\r\nu.Name AS 'Operador',\r\nround(dh.total, 2) AS 'Subtotal',\r\nround(dh.totaldiscounts, 2) AS 'Desconto',\r\nround(dh.totalservicetax, 2) AS 'Taxa Entrega',\r\nround(dh.paidamount, 2) AS 'Total Pago',\r\nCASE \r\nWHEN dh.deleted = 0 THEN 'Não'\r\nWHEN dh.deleted = 1 THEN 'Sim' \r\nEND AS 'Cancelado'\r\nFROM(SELECT * FROM documentsheaders\r\nUNION ALL\r\nSELECT * FROM docheaderscanceled) AS dh\r\nINNER JOIN users AS u\r\nON dh.closeuserid = u.id\r\n/*\r\nRelatorio: Vendas Delivery p/Data\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 26/05/2022\r\nATUALIZADO: 24/11/2022\r\n*/ @WHERE  @OTHERS ","SqlQueryWhere":"WHERE DATE(dh.CloseDate) BETWEEN @p_data1 AND @p_data2 AND salezoneareaobjectid >= 1999999","SqlOtherClauses":"ORDER BY dh.Number","Parameters":[{"Name":"@p_data1","Caption":"Data Inicial","ParameterType":"XDPeople.Framework.Date, XDPeople.NET, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null","DefaultValue":10,"DefaultValueType":2,"AvailableValueType":0,"AvailableValuesList":[]},{"Name":"@p_data2","Caption":"Data Final","ParameterType":"XDPeople.Framework.Date, XDPeople.NET, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null","DefaultValue":11,"DefaultValueType":2,"AvailableValueType":0,"AvailableValuesList":[]}],"Fields":[{"Name":"Numero","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Serie","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Tipo Doc","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Terminal","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Sessão Caixa","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Turno","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Num Delivery","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Cod Cliente","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Cliente","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Data Entrega","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Hora Entrega","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Operador","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Subtotal","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Desconto","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Taxa Entrega","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Total Pago","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Cancelado","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true}],"IsPivot":false,"ExternalConnection":"","AddToRibbon":true,"ShowInPos":true}
{"Guid":"87f5ddd2-67d2-49f7-9e44-85f650238a7a","Name":"Delivery p/ Entregador","Description":"Delivery p Entregador","SqlQuery":"/*\r\nRelatorio: Delivery p/ Entregador\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 03/07/2024\r\n*/\r\nSELECT \r\ndh.Number as 'Numero',\r\ndh.serieid as 'Serie',\r\ndh.documentkeyid as 'Tipo Doc',\r\ndh.terminal as 'Terminal',\r\ndh.NumDocCX as 'Sessao Caixa',\r\ndh.shift as 'Turno',\r\ndh.saleZoneAreaObjectId as 'Num Delivery',\r\ndh.entitykeyid as 'Cod Cliente',\r\ndh.entitydescription as 'Cliente',\r\nDATE_FORMAT(ds.OrderDate,'%d/%m/%Y - %H:%i:%s') as 'Data Pedido',\r\nDATE_FORMAT(ds.DeliveryDate,'%d/%m/%Y - %H:%i:%s') as 'Data Entrega',\r\nDATE_FORMAT(dh.CloseDate,'%d/%m/%Y - %H:%i:%s') as 'Data Finalizacao',\r\nu.Name as 'Operador Caixa',\r\nds.DeliveryEmployeeName as 'Entregador',\r\nround(dh.total, 2) as 'Subtotal',\r\nround(dh.totaldiscounts, 2) as 'Desconto',\r\nround(dh.totalservicetax, 2) as 'Taxa Entrega',\r\nround(dh.paidamount, 2) as 'Total Pago',\r\ncase \r\nwhen dh.deleted = 0 then 'Não'\r\nwhen dh.deleted = 1 then 'Sim' \r\nend as 'Cancelado'\r\nfrom(select * from documentsheaders\r\nunion all\r\nselect * from docheaderscanceled) as dh\r\ninner join users as u\r\non dh.closeuserid = u.id\r\nINNER JOIN deliverystatus AS ds\r\nON dh.Guid = ds.HeaderGuid\r\n/*\r\nRelatorio: Delivery p/ Entregador\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 03/07/2024\r\n*/ @WHERE  @OTHERS ","SqlQueryWhere":"where DATE(dh.CloseDate) between @p_data1 and @p_data2 AND ds.DeliveryEmployeeId = @p_entregador\r\n","SqlOtherClauses":"\r\norder by dh.Number","Parameters":[{"Name":"@p_data1","Caption":"Data inicial","ParameterType":"XDPeople.Framework.Date, XDPeople.NET, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null","DefaultValue":6,"DefaultValueType":2,"AvailableValueType":0,"AvailableValuesList":[]},{"Name":"@p_data2","Caption":"Data final","ParameterType":"XDPeople.Framework.Date, XDPeople.NET, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null","DefaultValue":7,"DefaultValueType":2,"AvailableValueType":0,"AvailableValuesList":[]},{"Name":"@p_entregador","Caption":"Entregador","ParameterType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Query":"SELECT \r\nid,\r\nname\r\nFROM users\r\nWHERE deliveryman = 1","DefaultValueType":0,"AvailableValueType":2,"AvailableValuesList":[]}],"Fields":[{"Name":"Numero","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Serie","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Tipo Doc","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Terminal","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Sessao Caixa","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Turno","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Num Delivery","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Cod Cliente","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Cliente","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Data Pedido","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Data Entrega","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Data Finalizacao","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Operador Caixa","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Entregador","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Subtotal","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Desconto","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Taxa Entrega","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Total Pago","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Cancelado","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true}],"IsPivot":false,"ExternalConnection":"","AddToRibbon":true,"ShowInPos":true}
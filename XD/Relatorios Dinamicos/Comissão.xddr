{"Guid":"c56617c9-d1ac-4506-81d1-4ff1ae6c9f20","Name":"Comissão","Description":"Comissão de Funcionários","SqlQuery":"SELECT users.Name AS 'Vendedor',\r\nround(SUM(documentsbodys.Quantity), 1) AS 'Quantidade',\r\nitems.Description AS 'Produto',\r\nround(SUM(items.SaleComission * documentsbodys.Quantity), 2) AS 'Total Comissão',\r\nitems.SaleComission AS 'Comissão Individual'\r\nFROM documentsbodys\r\nJOIN users ON documentsbodys.CreationUserId = users.Id\r\nJOIN items ON documentsbodys.ItemKeyId = items.KeyId\r\nGROUP BY items.Description, users.Name\r\nHAVING items.SaleComission > 0\r\n @WHERE  @OTHERS ","SqlQueryWhere":"","SqlOtherClauses":"","Parameters":[],"Fields":[{"Name":"Quantidade","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Produto","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Vendedor","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Total Comissão","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Comissão Individual","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true}],"IsPivot":false,"ExternalConnection":"","AddToRibbon":true,"ShowInPos":true}
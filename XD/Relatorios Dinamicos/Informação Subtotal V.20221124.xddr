{"Guid":"56b7cf0d-c401-4248-ba0c-644c44e160d5","Name":"Informação Subtotal","Description":"Informação Subtotal","SqlQuery":"/*\r\nRelatorio: Informacao Subtotal\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 24/05/2022\r\nATUALIZADO: 24/11/2022\r\n*/\r\n\r\nSELECT\r\ndocumentsheaderssub.SaleZoneAreaObjectId AS 'Mesa',\r\ndocumentsheaderssub.Number AS 'Sequência',\r\ndocumentsheaderssub.CreationDate 'Data',\r\nusers.Name AS 'Funcionário',\r\ndocumentsheaderssub.Terminal AS 'Terminal',\r\ndocumentsheaderssub.PaidAmount AS 'Valor'\r\n\r\nFROM documentsheaderssub\r\nINNER JOIN users ON users.Id = documentsheaderssub.CreationUserId\r\n\r\n/*\r\nRelatorio: Informacao Subtotal\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 24/05/2022\r\nATUALIZADO: 24/11/2022\r\n*/ @WHERE  @OTHERS ","SqlQueryWhere":"WHERE DATE(documentsheaderssub.CreationDate) BETWEEN @p_data1 AND @p_data2 AND documentsheaderssub.SaleZoneAreaObjectId = @p_mesa","SqlOtherClauses":"","Parameters":[{"Name":"@p_data1","Caption":"Data Inicial","ParameterType":"XDPeople.Framework.Date, XDPeople.NET, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null","DefaultValue":2,"DefaultValueType":2,"AvailableValueType":0,"AvailableValuesList":[]},{"Name":"@p_data2","Caption":"Data Final","ParameterType":"XDPeople.Framework.Date, XDPeople.NET, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null","DefaultValue":2,"DefaultValueType":2,"AvailableValueType":0,"AvailableValuesList":[]},{"Name":"@p_mesa","Caption":"Mesa/Comanda","ParameterType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","DefaultValueType":0,"AvailableValueType":0,"AvailableValuesList":[]}],"Fields":[{"Name":"Mesa","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Sequência","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Data","FieldType":"System.DateTime, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Funcionário","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Valor","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Terminal","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true}],"IsPivot":false,"ExternalConnection":"","AddToRibbon":true,"ShowInPos":true}
{"Guid":"6974684a-d523-4f73-8ab7-218f5bf0aef7","Name":"LANÇAMENTOS EM COMANDAS","Description":"LANÇAMENTOS EM COMANDAS","SqlQuery":"/*\r\nRelatorio: LANÇAMENTO EM COMANDA\r\nAutor: EDUARDO ESTEVAM\r\nRevenda: Lefer Automação Comercial\r\nDATA: 26/04/2023\r\n*/\r\n\r\nselect \r\nDATE_FORMAT(t.creationdate,'%y-%m-%d') as 'DATA',\r\nDATE_FORMAT(t.creationdate,'%H:%i:%s') as 'HORA', \r\nt.SaleZoneAreaObjectId as 'COMANDA', \r\nt2.name as 'USUARIO', \r\nt.terminal as 'TERMINAL', \r\nt.itemdescription as 'ITEM', \r\nround(t.quantity, 2) as 'QUANTIDADE', \r\nround(t.total, 2) as 'VALORTOTAL'  \r\nfrom documentsbodys t\r\n\r\ninner join users t2\r\non CreationUserId = t2.id\r\n\r\n\r\n/*OR USUARIO\r\nRelatorio: LANÇAMENTO EM COMANDA\r\nAutor: EDUARDO ESTEVAM\r\nRevenda: Lefer Automação Comercial\r\nDATA: 26/04/2023\r\n*/ @WHERE  @OTHERS ","SqlQueryWhere":"where date(creationdate) \r\nbetween (@p_data1) \r\nand (@p_data2)\r\nand SaleZoneAreaObjectId = @p_COMANDA;\r\n","SqlOtherClauses":"","Parameters":[{"Name":"@p_data1","Caption":"DATA INICIAL","ParameterType":"XDPeople.Framework.Date, XDPeople.NET, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null","DefaultValue":12,"DefaultValueType":2,"AvailableValueType":0,"AvailableValuesList":[]},{"Name":"@p_data2","Caption":"DATA FINAL","ParameterType":"XDPeople.Framework.Date, XDPeople.NET, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null","DefaultValue":2,"DefaultValueType":2,"AvailableValueType":0,"AvailableValuesList":[]},{"Name":"@p_COMANDA","Caption":"COMANDA","ParameterType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","DefaultValueType":0,"AvailableValueType":0,"AvailableValuesList":[]}],"Fields":[{"Name":"DATA","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"HORA","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"COMANDA","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"USUARIO","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"TERMINAL","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"ITEM","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"QUANTIDADE","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"VALORTOTAL","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true}],"IsPivot":false,"ExternalConnection":"","AddToRibbon":true,"ShowInPos":true}
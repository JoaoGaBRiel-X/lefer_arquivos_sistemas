{"Guid":"2ab8b658-be54-49ee-987d-78beb495e45a","Name":"Vendas NFC-e p/ Período","Description":"Vendas NFC-e","SqlQuery":"/*\r\nRelatorio: Vendas NFC-e p/ periodo\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 10/12/2021\r\nATUALIZADO: 16/01/2023\r\n*/\r\nSELECT \r\nq1.`NFC-e`,\r\nq1.`Serie`,\r\nq1.`Chave de acesso`,\r\nq1.`Data emissão`,\r\nq1.`Data cancelamento`,\r\nq1.`Status`,\r\nq1.`CPF/CNPJ`,\r\nq1.`Comanda/Mesa`,\r\nq1.`Terminal`,\r\nq1.`N Caixa`,\r\nq1.`Turno`,\r\nu.name AS 'Operador',\r\nq1.`Subtotal`,\r\nq1.`Desconto`,\r\nq1.`Tx Servico`,\r\nq1.`Total Pago`\r\nFROM (SELECT\r\ndh.Number AS 'NFC-e',\r\ndh.SerieId AS 'Serie',\r\nnf.accesskey AS 'Chave de acesso', \r\nnf.deliverydate AS 'Data emissão',  \r\nnf.cancelationdate AS 'Data Cancelamento',\r\nCASE \r\nWHEN nf.`status` = 2 THEN 'Autorizada'\r\nWHEN nf.`status` = 3 THEN 'Cancelada' \r\nEND AS 'Status' ,\r\nCASE\r\nWHEN dh.EntityVat = 999999990 THEN 'Não informado'\r\nELSE dh.EntityVat\r\nEND AS 'CPF/CNPJ',\r\ndh.SaleZoneAreaObjectId AS 'Comanda/Mesa',\r\ndh.Terminal AS 'Terminal',\r\nconvert(dh.NumDocCx, char) AS 'N Caixa',\r\ndh.Shift AS 'Turno',\r\nround(dh.total, 2) AS 'Subtotal',\r\nround(dh.totaldiscounts, 2) AS 'Desconto',\r\nround(dh.TotalServiceTax, 2) AS 'Tx Servico',\r\nround(dh.PaidAmount, 2) AS 'Total Pago',\r\ndh.closeuserid AS 'user'\r\n\r\n\r\nFROM salesnfce AS nf\r\nINNER JOIN\r\n(SELECT * FROM documentsheaders\r\nUNION ALL\r\nSELECT * FROM docheaderscanceled) AS dh\r\nON dh.Guid = nf.documentguid) AS q1\r\n\r\nINNER JOIN users AS u\r\nON q1.user = u.Id\r\n/*\r\nRelatorio: Vendas NFC-e p/ periodo\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 10/12/2021\r\nATUALIZADO: 16/01/2023\r\n*/ @WHERE  @OTHERS ","SqlQueryWhere":"WHERE DATE(q1.`Data emissão`) BETWEEN @p_datainicial AND @p_datafinal AND q1.`Status` = @p_status","SqlOtherClauses":"ORDER BY q1.`NFC-e`","Parameters":[{"Name":"@p_datainicial","Caption":"Data Inicial","ParameterType":"XDPeople.Framework.Date, XDPeople.NET, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null","DefaultValue":10,"DefaultValueType":2,"AvailableValueType":0,"AvailableValuesList":[]},{"Name":"@p_datafinal","Caption":"Data Final","ParameterType":"XDPeople.Framework.Date, XDPeople.NET, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null","DefaultValue":11,"DefaultValueType":2,"AvailableValueType":0,"AvailableValuesList":[]},{"Name":"@p_status","Caption":"Status","ParameterType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","DefaultValue":"Autorizada","DefaultValueType":1,"AvailableValueType":1,"AvailableValuesList":[{"Description":"Autorizada","Value":"Autorizada"},{"Description":"Cancelada","Value":"Cancelada"}]}],"Fields":[{"Name":"NFC-e","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Serie","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Chave de acesso","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Data emissão","FieldType":"System.DateTime, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"Formatting":"g","IsVisible":true},{"Name":"Data Cancelamento","FieldType":"System.DateTime, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"Formatting":"g","IsVisible":true},{"Name":"Status","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"CPF/CNPJ","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Comanda/Mesa","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Terminal","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"N Caixa","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Turno","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Operador","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Subtotal","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"Formatting":" \\R$ ###,###,###,##0.00","IsVisible":true},{"Name":"Desconto","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"Formatting":" \\R$ ###,###,###,##0.00","IsVisible":true},{"Name":"Tx Servico","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"Formatting":" \\R$ ###,###,###,##0.00","IsVisible":true},{"Name":"Total Pago","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"Formatting":" \\R$ ###,###,###,##0.00","IsVisible":true}],"IsPivot":false,"ExternalConnection":"","AddToRibbon":true,"ShowInPos":true}
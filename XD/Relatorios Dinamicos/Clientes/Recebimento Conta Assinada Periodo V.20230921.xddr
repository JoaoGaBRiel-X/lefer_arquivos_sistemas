{"Guid":"6744f9e7-c74f-46a0-914d-cee15caa6b39","Name":"Receb C.Assinada Pe","Description":"Rec C.Assin Pe","SqlQuery":"/*\r\nRelatorio: Receb C.Assinada Pe\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 07/08/2023\r\nATUALIZADO: 07/08/2023\r\n*/\r\nselect \r\nrh.Number as 'Documento',\r\nDATE_FORMAT(rh.CreationDate,'%d/%m/%Y') as 'Data',\r\nu.Name as 'Usuario',\r\nrh.NumDocCx as 'Sessao Cx',\r\nrh.EntityDescription as 'Cliente',\r\nround(rh.Total, 2) as 'Valor Recebido',\r\npt.Description as 'Tipo Pagamento',\r\ncase\r\n\twhen rh.Deleted = 1 then 'Sim'\r\n\twhen rh.Deleted = 0 then 'Não'\r\nend as 'Cancelado'\r\nfrom receiptsheaders rh\r\ninner join users u on rh.CreationUserId = u.Id\r\ninner join (select * from receiptspaymentdetails where ischange = 0) rph on rph.DocumentGuid = rh.Guid\r\ninner join xconfigpaymenttypes pt on rph.PaymentTypeId = pt.Id\r\n/*\r\nRelatorio: Receb C.Assinada Pe\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 07/08/2023\r\nATUALIZADO: 07/08/2023\r\n*/ @WHERE  @OTHERS ","SqlQueryWhere":"WHERE DATE(rh.CreationDate) BETWEEN @p_data1 AND @p_data2","SqlOtherClauses":"","Parameters":[{"Name":"@p_data1","Caption":"Data Inicial","ParameterType":"XDPeople.Framework.Date, XDPeople.NET, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null","DefaultValue":2,"DefaultValueType":2,"AvailableValueType":0,"AvailableValuesList":[]},{"Name":"@p_data2","Caption":"Data Final","ParameterType":"XDPeople.Framework.Date, XDPeople.NET, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null","DefaultValue":2,"DefaultValueType":2,"AvailableValueType":0,"AvailableValuesList":[]}],"Fields":[{"Name":"Documento","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Data","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Usuario","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Sessao Cx","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Cliente","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Valor Recebido","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Tipo Pagamento","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Cancelado","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true}],"IsPivot":false,"ExternalConnection":"","AddToRibbon":true,"ShowInPos":true}
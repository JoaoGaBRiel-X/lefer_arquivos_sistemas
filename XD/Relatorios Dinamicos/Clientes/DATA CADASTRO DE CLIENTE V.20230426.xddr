{"Guid":"07d730c2-f017-4b90-876b-3e43a06e4cd5","Name":"DATA CADASTRO DE CLIENTE","Description":"DATA CADASTRO DE CLIENTE","SqlQuery":"/*\r\nRelatorio: DATA CADASTRO DO CLIENTE\r\nAutor: EDUARDO ESTEVAM\r\nRevenda: Lefer Automação Comercial\r\nDATA: 24/04/2023\r\n*/\r\nselect \r\nname as \"CLIENTE\", \r\ndate(creationdate) as \"DATA\" \r\nfrom entities\r\nwhere date(creationdate) \r\nbetween date(@p_data1) \r\nand date(@p_data2);\r\n\r\n\r\n/*\r\nRelatorio: DATA CADASTRO DO CLIENTE\r\nAutor: EDUARDO ESTEVAM\r\nRevenda: Lefer Automação Comercial\r\nDATA: 24/04/2023\r\n*/\r\n @WHERE  @OTHERS ","SqlQueryWhere":"","SqlOtherClauses":"","Parameters":[{"Name":"@p_data1","Caption":"Data inicial","ParameterType":"XDPeople.Framework.Date, XDPeople.NET, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null","DefaultValue":12,"DefaultValueType":2,"AvailableValueType":0,"AvailableValuesList":[]},{"Name":"@p_data2","Caption":"Data final","ParameterType":"XDPeople.Framework.Date, XDPeople.NET, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null","DefaultValue":2,"DefaultValueType":2,"AvailableValueType":0,"AvailableValuesList":[]}],"Fields":[{"Name":"CLIENTE","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"DATA","FieldType":"System.DateTime, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true}],"IsPivot":false,"ExternalConnection":"","AddToRibbon":true,"ShowInPos":true}
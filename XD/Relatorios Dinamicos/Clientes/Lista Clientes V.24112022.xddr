{"Guid":"0bb17b5b-35ac-4908-b1e0-46477197539e","Name":"Lista Clientes","Description":"Lista Clientes","SqlQuery":"/*\r\nRelatorio: Lista Clientes\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 24/11/2022\r\n*/\r\nselect \r\nkeyid as 'Codigo',\r\nname as 'Nome',\r\nCONCAT('(', SUBSTR(mobilephone1, 1, 2), ')', SUBSTR(mobilephone1, 3, 5), '-', SUBSTR(mobilephone1, 8)) as 'Celular',\r\nDATE_FORMAT(dateofbirth,'%d/%m/%Y') as 'Aniversario'\r\nfrom entities\r\n/*\r\nRelatorio: Lista Clientes\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 24/11/2022\r\n*/ @WHERE  @OTHERS ","SqlQueryWhere":"","SqlOtherClauses":"","Parameters":[],"Fields":[{"Name":"Codigo","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Nome","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Celular","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Aniversario","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true}],"IsPivot":false,"ExternalConnection":"","AddToRibbon":true,"ShowInPos":true}
{"Guid":"877931e7-6794-4098-81d1-920d4397e389","Name":"Frequencia Cliente","Description":"Freq Cliente","SqlQuery":"/*\r\nRelatorio: Frequencia Cliente\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 24/11/2022\r\n*/\r\nSELECT\r\ndh.number AS 'Documento',\r\nDATE_FORMAT(dh.creationdate,'%d/%m/%Y') AS 'Data',\r\ndh.entitykeyid AS 'Codigo',\r\ndh.entitydescription AS 'Nome',\r\nROUND(dh.paidamount, 2) AS 'Valor Pago',\r\npt.Description AS 'F Pagamento'\r\n\r\nFROM \r\ndocumentsheaders dh\r\nINNER JOIN\r\nxconfigpaymenttypes pt\r\nON \r\ndh.PaymentType = pt.Id\r\n/*\r\nRelatorio: Frequencia Cliente\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 24/11/2022\r\n*/ @WHERE  @OTHERS ","SqlQueryWhere":"WHERE DATE(dh.creationdate) >= @p_data1 AND dh.creationdate <= @p_data2 AND dh.entitykeyid = @p_cliente","SqlOtherClauses":"","Parameters":[{"Name":"@p_data1","Caption":"Data inicial","ParameterType":"XDPeople.Framework.Date, XDPeople.NET, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null","DefaultValue":16,"DefaultValueType":2,"AvailableValueType":0,"AvailableValuesList":[]},{"Name":"@p_data2","Caption":"Data Final","ParameterType":"XDPeople.Framework.Date, XDPeople.NET, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null","DefaultValue":1,"DefaultValueType":2,"AvailableValueType":0,"AvailableValuesList":[]},{"Name":"@p_cliente","Caption":"Codigo Cliente","ParameterType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","EntityType":"XDPeople.Entities.Entity, XDPeople.NET, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null","DefaultValueType":0,"AvailableValueType":0,"AvailableValuesList":[]}],"Fields":[{"Name":"Documento","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Data","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Codigo","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Nome","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Valor Pago","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"F Pagamento","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true}],"IsPivot":false,"ExternalConnection":"","AddToRibbon":true,"ShowInPos":true}
{"Guid":"ab80924c-04f3-4669-9d9f-2a220cee6509","Name":"Pessoas p/ Dia","Description":"Pessoas por dia","SqlQuery":"/*\r\nRelatorio: Pessoas p/Dia\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 24/11/2022\r\n*/\r\nSELECT \r\nDATE_FORMAT(creationdate,'%d/%m/%Y') AS 'Data',\r\nSUM(CASE WHEN numberpersons = 0 THEN 1 ELSE numberpersons END) AS 'Pessoas'\r\nFROM documentsheaders\r\n/*\r\nRelatorio: Pessoas p/Dia\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 24/11/2022\r\n*/ @WHERE  @OTHERS ","SqlQueryWhere":"WHERE DATE(creationdate) BETWEEN @p_data1 AND @p_data2","SqlOtherClauses":"GROUP BY \r\nDATE(creationdate)","Parameters":[{"Name":"@p_data1","Caption":"Data Inicial","ParameterType":"XDPeople.Framework.Date, XDPeople.NET, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null","DefaultValue":12,"DefaultValueType":2,"AvailableValueType":0,"AvailableValuesList":[]},{"Name":"@p_data2","Caption":"Data Final","ParameterType":"XDPeople.Framework.Date, XDPeople.NET, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null","DefaultValue":13,"DefaultValueType":2,"AvailableValueType":0,"AvailableValuesList":[]}],"Fields":[{"Name":"Data","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Pessoas","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true}],"IsPivot":false,"ExternalConnection":"","AddToRibbon":true,"ShowInPos":true}
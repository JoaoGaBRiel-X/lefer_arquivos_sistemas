{"Guid":"93a98929-30ea-4de5-a34a-eeeec08fad62","Name":"Aniversariantes","Description":"Aniversariantes","SqlQuery":"/*\r\nRelatorio: Aniversariantes\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 24/11/2022\r\n*/\r\nselect \r\nkeyid as 'Codigo',\r\nname as 'Nome',\r\nCONCAT('(', SUBSTR(mobilephone1, 1, 2), ')', SUBSTR(mobilephone1, 3, 5), '-', SUBSTR(mobilephone1, 8)) as 'Celular',\r\nDATE_FORMAT(dateofbirth,'%d/%m/%Y') as 'Aniversario',\r\nFLOOR(DATEDIFF(NOW(), dateofbirth) / 365) AS 'Idade'\r\nfrom entities\r\n/*\r\nRelatorio: Aniversariantes\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 24/11/2022\r\n*/ @WHERE  @OTHERS ","SqlQueryWhere":"where MONTH(dateofbirth) = @p_mes","SqlOtherClauses":"","Parameters":[{"Name":"@p_mes","Caption":"Mês","ParameterType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","DefaultValue":0,"DefaultValueType":1,"AvailableValueType":1,"AvailableValuesList":[{"Description":"01-Janeiro","Value":1},{"Description":"02-Fevereiro","Value":2},{"Description":"03-Março","Value":3},{"Description":"04-Abril","Value":4},{"Description":"05-Maio","Value":5},{"Description":"06-Junho","Value":6},{"Description":"07-Julho","Value":7},{"Description":"08-Agosto","Value":8},{"Description":"09-Setembro","Value":9},{"Description":"10-Outubro","Value":10},{"Description":"11-Novembro","Value":11},{"Description":"12-Dezembro","Value":12}]}],"Fields":[{"Name":"Codigo","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Nome","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Celular","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Aniversario","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Idade","FieldType":"System.Int64, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true}],"IsPivot":false,"ExternalConnection":"","AddToRibbon":true,"ShowInPos":true}
{"Guid":"a6080180-81b7-4111-b95d-732bc8413365","Name":"Faturas Det Pag p/ Data","Description":"F D Pag p Data","SqlQuery":"/*\r\nRelatorio: Faturas Det Pag p/ Data\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 13/01/2023\r\nATUALIZADO: 13/01/2023\r\n*/\r\nSELECT\r\ndh.documentkeyid AS 'Tipo Doc',\r\ndh.Number AS 'Numero',\r\ndh.serieid AS 'Serie',\r\ndh.terminal AS 'Terminal',\r\ndh.NumDocCX AS 'Sessão Caixa',\r\ndh.shift AS 'Turno',\r\ndh.saleZoneAreaObjectId AS 'Comanda/Mesa',\r\nDATE_FORMAT(dh.CloseDate,'%d/%m/%Y') AS 'Data Fecham',\r\nDATE_FORMAT(dh.CloseDate,'%H:%i:%s') AS 'Hora Fecham',\r\nu.Name AS 'Operador',\r\nround(dh.total, 2) AS 'Subtotal',\r\nround(dh.totaldiscounts, 2) AS 'Desconto',\r\nround(dh.totalservicetax, 2) AS 'Taxa Serviço',\r\nround(dh.paidamount, 2) AS 'Total',\r\nround(ipd.total, 2) AS 'Valor Pago',\r\npt.Description as 'F Pagamento',\r\nCASE \r\nWHEN dh.deleted = 0 THEN 'Não'\r\nWHEN dh.deleted = 1 THEN 'Sim' \r\nEND AS 'Cancelado'\r\nFROM invoicepaymentdetails AS ipd\r\nINNER JOIN (SELECT * FROM documentsheaders\r\nUNION ALL\r\nSELECT * FROM docheaderscanceled) AS dh\r\nON ipd.InvoiceNumber = dh.Number\r\nINNER JOIN users AS u\r\nON dh.closeuserid = u.id\r\nINNER JOIN xconfigpaymenttypes AS pt\r\nON ipd.PaymentTypeId = pt.Id\r\n/*\r\nRelatorio: Faturas Det Pag p/ Data\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 13/01/2023\r\nATUALIZADO: 13/01/2023\r\n*/ @WHERE  @OTHERS ","SqlQueryWhere":"WHERE DATE(dh.CloseDate) BETWEEN @p_data1 AND @p_data2","SqlOtherClauses":"ORDER BY dh.Number","Parameters":[{"Name":"@p_data1","Caption":"Data Inicial","ParameterType":"XDPeople.Framework.Date, XDPeople.NET, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null","DefaultValue":12,"DefaultValueType":2,"AvailableValueType":0,"AvailableValuesList":[]},{"Name":"@p_data2","Caption":"Data Final","ParameterType":"XDPeople.Framework.Date, XDPeople.NET, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null","DefaultValue":2,"DefaultValueType":2,"AvailableValueType":0,"AvailableValuesList":[]}],"Fields":[{"Name":"Tipo Doc","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Numero","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Serie","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Terminal","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Sessão Caixa","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Turno","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Comanda/Mesa","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Data Fecham","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Hora Fecham","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Operador","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Subtotal","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"Formatting":" \\R$ ###,###,###,##0.00","IsVisible":true},{"Name":"Desconto","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"Formatting":" \\R$ ###,###,###,##0.00","IsVisible":true},{"Name":"Taxa Serviço","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"Formatting":" \\R$ ###,###,###,##0.00","IsVisible":true},{"Name":"Total","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"Formatting":" \\R$ ###,###,###,##0.00","IsVisible":true},{"Name":"Valor Pago","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"Formatting":" \\R$ ###,###,###,##0.00","IsVisible":true},{"Name":"F Pagamento","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Cancelado","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true}],"IsPivot":false,"ExternalConnection":"","AddToRibbon":true,"ShowInPos":true}
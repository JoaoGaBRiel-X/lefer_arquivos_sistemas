{"Guid":"93daae65-addf-42c4-bfc4-466e30153d61","Name":"Faturamento NFC-e Mensal","Description":"Fat NFC-e Mensal","SqlQuery":"/*\r\nRelatorio: Faturamento NFC-e Mensal\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 09/05/2023\r\nATUALIZADO: 09/05/2023\r\n*/\r\nSELECT \r\nDATE_FORMAT(q1.`Data emissão`, \"%m/%Y\") as 'Mes',\r\nSUM(q1.`Subtotal`) as 'Subtotal',\r\nSUM(q1.`Desconto`) as 'Desconto',\r\nSUM(q1.`Tx Servico`)as 'Taxa Servico',\r\nSUM(q1.`Total Pago`) as 'Total'\r\nFROM (SELECT\r\ndh.Number AS 'NFC-e',\r\ndh.SerieId AS 'Serie',\r\nnf.accesskey AS 'Chave de acesso', \r\nnf.deliverydate AS 'Data emissão',  \r\nnf.cancelationdate AS 'Data Cancelamento',\r\nCASE \r\nWHEN nf.`status` = 2 THEN 'Autorizada'\r\nWHEN nf.`status` = 3 THEN 'Cancelada' \r\nEND AS 'Status' ,\r\nCASE\r\nWHEN dh.EntityVat = 999999990 THEN 'Não informado'\r\nELSE dh.EntityVat\r\nEND AS 'CPF/CNPJ',\r\ndh.SaleZoneAreaObjectId AS 'Comanda/Mesa',\r\ndh.Terminal AS 'Terminal',\r\nconvert(dh.NumDocCx, char) AS 'N Caixa',\r\ndh.Shift AS 'Turno',\r\nround(dh.total, 2) AS 'Subtotal',\r\nround(dh.totaldiscounts, 2) AS 'Desconto',\r\nround(dh.TotalServiceTax, 2) AS 'Tx Servico',\r\nround(dh.PaidAmount, 2) AS 'Total Pago',\r\ndh.closeuserid AS 'user'\r\n\r\n\r\nFROM salesnfce AS nf\r\nINNER JOIN\r\n(SELECT * FROM documentsheaders\r\nUNION ALL\r\nSELECT * FROM docheaderscanceled) AS dh\r\nON dh.Guid = nf.documentguid) AS q1\r\n\r\nINNER JOIN users AS u\r\nON q1.user = u.Id\r\n/*\r\nRelatorio: Faturamento NFC-e Mensal\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 09/05/2023\r\nATUALIZADO: 09/05/2023\r\n*/ @WHERE  @OTHERS ","SqlQueryWhere":"where EXTRACT(YEAR FROM q1.`Data emissão`) = @p_ano","SqlOtherClauses":"group by EXTRACT(MONTH FROM q1.`Data emissão`)","Parameters":[{"Name":"@p_ano","Caption":"Ano","ParameterType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","DefaultValueType":0,"AvailableValueType":0,"AvailableValuesList":[]}],"Fields":[{"Name":"Mes","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Subtotal","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Desconto","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Taxa Servico","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Total","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true}],"IsPivot":false,"ExternalConnection":"","AddToRibbon":true,"ShowInPos":true}
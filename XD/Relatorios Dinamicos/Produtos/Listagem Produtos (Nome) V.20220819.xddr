{"Guid":"d4fdd6ac-58c8-4f99-9a54-d8440c723368","Name":"Listagem Produtos (Nome)","Description":"Lista Prod","SqlQuery":"/*\r\nRelatorio: Listagem Produtos (Nome)\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 18/08/2022\r\n*/\r\nselect \r\nkeyid as 'Cod',\r\nDescription as 'Nome',\r\nROUND(RetailPrice1, 2) as 'Valor' \r\nfrom items\r\n/*\r\nRelatorio: Listagem Produtos (Nome)\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 18/08/2022\r\n*/ @WHERE  @OTHERS ","SqlQueryWhere":"","SqlOtherClauses":"order by description","Parameters":[],"Fields":[{"Name":"Cod","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Nome","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Valor","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true}],"IsPivot":false,"ExternalConnection":"","AddToRibbon":true,"ShowInPos":true}
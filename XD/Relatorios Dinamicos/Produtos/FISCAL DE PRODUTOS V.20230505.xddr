{"Guid":"d14bdb45-53ae-4fe9-9ebb-a84d08863d71","Name":"FISCAL DE PRODUTOS","Description":"FISCAL DE PRODUTOS","SqlQuery":"/*\r\nRelatorio: INFORMACAO FISCAL PRODUTOS\r\nAutor: EDUARDO ESTEVAM\r\nRevenda: Lefer Automação Comercial\r\nDATA: 05/05/2023\r\n*/\r\n\r\nselect \r\nt1.id as 'CODIGO',\r\nt1.description as 'PRODUTO', \r\nt1.ncmcode as 'NCM', \r\nt4.code as 'CEST',\r\nt1.cfop as 'CFOP', \r\nt2.code as 'PIS', \r\nt3.code as 'COFINS'\r\nfrom items t1\r\n\r\ninner join fiscaltaxesbrazil t2\r\non pisoutcode = t2.id\r\n\r\ninner join fiscaltaxesbrazil t3\r\non cofinsoutcode = t3.id\r\n\r\ninner join fiscaltaxesbrazil t4\r\non icmscode = t4.id\r\n\r\n\r\n/*\r\nRelatorio: INFORMACAO FISCAL PRODUTOS\r\nAutor: EDUARDO ESTEVAM\r\nRevenda: Lefer Automação Comercial\r\nDATA: 05/05/2023\r\n*/ @WHERE  @OTHERS ","SqlQueryWhere":"","SqlOtherClauses":"","Parameters":[],"Fields":[{"Name":"CODIGO","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"PRODUTO","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"NCM","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"CEST","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"CFOP","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"PIS","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"COFINS","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true}],"IsPivot":false,"ExternalConnection":"","AddToRibbon":true,"ShowInPos":true}
{"Guid":"67b015b1-6ac0-4a9c-bae3-ad5a551ad930","Name":"Itens Cancelados","Description":"Itens Cancelados","SqlQuery":"/*\r\nRelatorio: Itens Cancelados\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 26/05/2022\r\nATUALIZADO: 25/02/2026\r\n*/\r\nSELECT\r\nt2.name AS 'Us Cancelamento',\r\nt1.salezoneareaobjectid AS 'Mesa/Comanda',\r\nt1.itemgroupid AS 'Id Familia',\r\nt3.Description AS 'Familia',\r\nt1.itemdescription AS 'Produto',\r\nabs(t1.quantity) AS 'QNT',\r\nabs(t1.total) AS 'Valor',\r\nt1.terminal AS 'Terminal',\r\nDATE_FORMAT(t1.sessiondate,'%H:%i:%s') AS 'Hora Cancelamento'\r\nFROM documentsbodysdeleted t1\r\nINNER JOIN users t2 ON t1.CloseUserId = t2.Id\r\nINNER JOIN itemsgroups t3 ON t1.ItemGroupId = t3.Id\r\n/*\r\nRelatorio: Itens Cancelados\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 26/05/2022\r\nATUALIZADO: 25/02/2026\r\n*/ @WHERE  @OTHERS ","SqlQueryWhere":"WHERE DATE(t1.sessiondate) BETWEEN @p_datainicial AND @p_datafinal","SqlOtherClauses":"ORDER BY t1.salezoneareaobjectid, t1.ItemGroupId, t1.itemdescription","Parameters":[{"Name":"@p_datainicial","Caption":"Data Inicial","ParameterType":"XDPeople.Framework.Date, XDPeople.NET, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null","DefaultValue":2,"DefaultValueType":2,"AvailableValueType":0,"AvailableValuesList":[]},{"Name":"@p_datafinal","Caption":"Data Final","ParameterType":"XDPeople.Framework.Date, XDPeople.NET, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null","DefaultValue":2,"DefaultValueType":2,"AvailableValueType":0,"AvailableValuesList":[]}],"Fields":[{"Name":"Us Cancelamento","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Mesa/Comanda","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Id Familia","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Familia","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Produto","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"QNT","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Valor","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Terminal","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Hora Cancelamento","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true}],"IsPivot":false,"ExternalConnection":"","AddToRibbon":true,"ShowInPos":true}
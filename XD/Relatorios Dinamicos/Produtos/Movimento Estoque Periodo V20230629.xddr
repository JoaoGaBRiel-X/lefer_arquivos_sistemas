{"Guid":"019b72ea-a3be-4877-b547-8dda3574a117","Name":"Movimento Estoque Periodo","Description":"Mov Est Periodo","SqlQuery":"/*\r\nRelatorio: Movimento Estoque Periodo\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 29/06/2023\r\nATUALIZADO: 29/06/2023\r\n*/\r\nselect\r\ndb1.KeyId as 'Cod',\r\ndb1.Description as 'Nome',\r\ncase\r\n when (db2.Quantity OR db3.Quantity OR db4.Quantity OR db5.Quantity) is not null then ROUND(db1.CurrentStock, 2) - IF(SUM(db2.Quantity) is not null, ROUND(SUM(db2.Quantity), 2), 0) + IF(SUM(db3.Quantity) is not null, ROUND(SUM(db3.Quantity), 2), 0) - IF(SUM(db4.Quantity) is not null, ROUND(SUM(db4.Quantity), 2), 0) + IF(SUM(db5.Quantity) is not null, ROUND(SUM(db5.Quantity), 2), 0)\r\nelse ROUND(db1.CurrentStock, 2)\r\nend as 'Inicial',\r\ncase\r\n when (db2.Quantity OR db4.Quantity) is not null then IF(SUM(db2.Quantity) is not null, ROUND(SUM(db2.Quantity), 2), 0) + IF(SUM(db4.Quantity) is not null, ROUND(SUM(db4.Quantity), 2), 0)\r\nelse ROUND(0,2)\r\nend as 'Entr',\r\ncase\r\n when (db3.Quantity OR db5.Quantity) is not null then IF(SUM(db3.Quantity) is not null, ROUND(SUM(db3.Quantity), 2), 0) + IF(SUM(db5.Quantity) is not null, ROUND(SUM(db5.Quantity), 2), 0)\r\nelse ROUND(0,2)\r\nend as 'Saida',\r\nROUND(db1.CurrentStock,2) as 'Atual'\r\n\r\nfrom items as db1\r\nleft join (select ItemKeyId, ItemDescription, SUM(Quantity) as 'Quantity', sessiondate from documentsbodys where stockflow = 1 and sessiondate between DATE(@p_data1) and NOW() group by ItemKeyId) as db2\r\non db1.KeyId = db2.ItemKeyId\r\nleft join (select ItemKeyId, ItemDescription, SUM(Quantity) as 'Quantity', sessiondate from documentsbodys where stockflow = 2 and sessiondate between DATE(@p_data1) and NOW() group by ItemKeyId) as db3\r\non db1.KeyId = db3.ItemKeyId\r\nleft join (select db.ItemKeyId as 'ItemKeyId', db.ItemDescription, db.SessionDate as 'SessionDate', SUM(it.Quantity) as 'Quantity' from documentsbodys db inner join itemstockorders it on db.Guid = it.DetailGuid where db.stockflow = 5  and it.StockFlow = 1 and sessiondate between DATE(@p_data1) and NOW() group by db.ItemKeyId) as db4\r\non db1.KeyId = db4.ItemKeyId\r\nleft join (select db.ItemKeyId as 'ItemKeyId', db.ItemDescription, db.SessionDate as 'SessionDate', SUM(it.Quantity) as 'Quantity' from documentsbodys db inner join itemstockorders it on db.Guid = it.DetailGuid where db.stockflow = 5  and it.StockFlow = 2 and sessiondate between DATE(@p_data1) and NOW() group by db.ItemKeyId) as db5\r\non db1.KeyId = db5.ItemKeyId\r\n/*\r\nRelatorio: Movimento Estoque Periodo\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 29/06/2023\r\nATUALIZADO: 29/06/2023\r\n*/ @WHERE  @OTHERS ","SqlQueryWhere":"where db1.StockControl = 1","SqlOtherClauses":"group by db1.keyid","Parameters":[{"Name":"@p_data1","Caption":"Data inicial","ParameterType":"XDPeople.Framework.Date, XDPeople.NET, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null","DefaultValue":6,"DefaultValueType":2,"AvailableValueType":0,"AvailableValuesList":[]}],"Fields":[{"Name":"Cod","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Nome","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Inicial","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Entr","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Saida","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Atual","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true}],"IsPivot":false,"ExternalConnection":"","AddToRibbon":true,"ShowInPos":true}
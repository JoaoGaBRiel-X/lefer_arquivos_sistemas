{"Guid":"ebc6d36c-0465-4779-8e90-c86d732a5d37","Name":"Margem Bruta p/ Produto","Description":"Margem Bruta p Produto","SqlQuery":"/*\r\nRelatorio: Margem Bruta p/ Produto\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 31/07/2025\r\nATUALIZADO: 31/07/2025\r\n*/\r\nSELECT\r\ndb.ItemKeyId AS 'ID',\r\ndb.itemdescription as 'Nome',\r\ndb.itemgroupid as 'ID Familia',\r\nig.description as 'Familia',\r\nSUM(db.quantity) as 'QTD Total',\r\nROUND(SUM(db.retailprice * db.quantity) / SUM(db.quantity), 2) AS 'V Unit Med',\r\nROUND(SUM(db.total), 2) AS 'Subtotal Total',\r\nROUND(SUM(db.totaldiscounts), 2) AS 'Desconto Total',\r\nROUND(SUM(db.servicetaxvalue), 2) AS 'T Servico Total',\r\nROUND(SUM(db.totalamount), 2) AS 'Total',\r\nROUND(SUM(db.quantity) * it.PurchasePrice, 2) AS 'Custo Total',\r\nROUND(SUM(db.totalamount) - (SUM(db.quantity) * it.PurchasePrice), 2) AS 'Margem Bruta'\r\nFROM documentsbodys AS db\r\nINNER JOIN users AS u\r\nON db.closeuserid = u.id\r\nINNER JOIN itemsgroups AS ig\r\nON db.ItemGroupId = ig.Id\r\nINNER JOIN items AS it\r\nON db.ItemKeyId = it.KeyId\r\n/*\r\nRelatorio: Margem Bruta p/ Produto\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 31/07/2025\r\nATUALIZADO: 31/07/2025\r\n*/ @WHERE  @OTHERS ","SqlQueryWhere":"WHERE DATE(db.CloseDate) BETWEEN @p_data1 AND @p_data2","SqlOtherClauses":"GROUP BY db.ItemKeyId","Parameters":[{"Name":"@p_data1","Caption":"Data Inicial","ParameterType":"XDPeople.Framework.Date, XDPeople.NET, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null","DefaultValue":6,"DefaultValueType":2,"AvailableValueType":0,"AvailableValuesList":[]},{"Name":"@p_data2","Caption":"Data Final","ParameterType":"XDPeople.Framework.Date, XDPeople.NET, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null","DefaultValue":2,"DefaultValueType":2,"AvailableValueType":0,"AvailableValuesList":[]}],"Fields":[{"Name":"ID","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Nome","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"ID Familia","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Familia","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"QTD Total","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"V Unit Med","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Subtotal Total","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Desconto Total","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"T Servico Total","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Total","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Custo Total","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Margem Bruta","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true}],"IsPivot":false,"ExternalConnection":"","AddToRibbon":true,"ShowInPos":true}
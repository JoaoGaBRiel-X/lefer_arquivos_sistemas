{"Guid":"be8fe75d-0080-4b4b-912d-4c376595ce01","Name":"Vendas Produtos p/ Termin","Description":"Vendas Produtos p Terminal","SqlQuery":"/*\r\nRelatorio: Vendas Produtos p/ Terminal\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 31/07/2025\r\nATUALIZADO: 31/07/2025\r\n*/\r\nSELECT\r\ndb.Number AS 'Numero',\r\ndb.serieid AS 'Serie',\r\ndb.itemgroupid as 'ID Familia',\r\nig.description as 'Familia',\r\ndb.itemdescription as 'Nome',\r\ndb.quantity as 'Quantidade',\r\ndb.terminal AS 'Terminal',\r\ndb.shift AS 'Turno',\r\ndb.saleZoneAreaObjectId AS 'Comanda/Mesa',\r\nDATE_FORMAT(db.CloseDate,'%d/%m/%Y') AS 'Data Fecham',\r\nDATE_FORMAT(db.CloseDate,'%H:%i:%s') AS 'Hora Fecham',\r\nu.Name AS 'Operador',\r\nround(db.retailprice, 2) AS 'V Unit',\r\nround(db.total, 2) AS 'Subtotal',\r\nround(db.totaldiscounts, 2) AS 'Desconto',\r\nround(db.servicetaxvalue, 2) AS 'Taxa Serviço',\r\nround(db.totalamount, 2) AS 'Total Pago'\r\nFROM documentsbodys AS db\r\nINNER JOIN users AS u\r\nON db.closeuserid = u.id\r\nINNER JOIN itemsgroups AS ig\r\nON db.ItemGroupId = ig.Id\r\n/*\r\nRelatorio: Vendas Produtos p/ Terminal\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 31/07/2025\r\nATUALIZADO: 31/07/2025\r\n*/ @WHERE  @OTHERS ","SqlQueryWhere":"WHERE DATE(db.CloseDate) BETWEEN @p_data1 AND @p_data2 AND db.terminal = @p_terminal","SqlOtherClauses":"ORDER BY db.Number","Parameters":[{"Name":"@p_data1","Caption":"Data Inicial","ParameterType":"XDPeople.Framework.Date, XDPeople.NET, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null","DefaultValue":2,"DefaultValueType":2,"AvailableValueType":0,"AvailableValuesList":[]},{"Name":"@p_data2","Caption":"Data Final","ParameterType":"XDPeople.Framework.Date, XDPeople.NET, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null","DefaultValue":2,"DefaultValueType":2,"AvailableValueType":0,"AvailableValuesList":[]},{"Name":"@p_terminal","Caption":"Terminal","ParameterType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","DefaultValue":1,"Query":"SELECT id, description FROM xconfigterminals","DefaultValueType":1,"AvailableValueType":2,"AvailableValuesList":[]}],"Fields":[{"Name":"Numero","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Serie","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"ID Familia","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Familia","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Nome","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Quantidade","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Terminal","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Turno","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Comanda/Mesa","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Data Fecham","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Hora Fecham","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Operador","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"V Unit","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Subtotal","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Desconto","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Taxa Serviço","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Total Pago","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true}],"IsPivot":false,"ExternalConnection":"","AddToRibbon":true,"ShowInPos":true}
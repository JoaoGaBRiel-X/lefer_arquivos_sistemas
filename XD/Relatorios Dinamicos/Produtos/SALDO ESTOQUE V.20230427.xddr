{"Guid":"1ae370e0-ba4f-4efe-84cf-633b6bacac53","Name":"SALDO ESTOQUE","Description":"SALDO ESTOQUE","SqlQuery":"/*\r\nRelatorio:SALDO ESTOQUE\r\nAutor: EDUARDO ESTEVAM\r\nRevenda: Lefer Automação Comercial\r\nDATA: 27/04/2023\r\n*/\r\n\r\nselect \r\nt.id as 'CODIGO',\r\nt.description as 'PRODUTO', \r\nt2.description as 'FAMILIA', \r\nround(t.currentstock, 2) as 'ESTOQUE ATUAL'\r\n\r\nfrom items t\r\n\r\ninner join itemsgroups t2\r\non groupid = t2.id\r\n\r\nwhere t.stockcontrol = 1 and t.discontinued = 0\r\n\r\n/*\r\nRelatorio: SALDO ESTOQUE\r\nAutor: EDUARDO ESTEVAM\r\nRevenda: Lefer Automação Comercial\r\nDATA: 27/04/2023\r\n*/\r\n\r\n\r\n @WHERE  @OTHERS ","SqlQueryWhere":"","SqlOtherClauses":"","Parameters":[],"Fields":[{"Name":"CODIGO","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"PRODUTO","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"FAMILIA","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"ESTOQUE ATUAL","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true}],"IsPivot":false,"ExternalConnection":"","AddToRibbon":true,"ShowInPos":true}
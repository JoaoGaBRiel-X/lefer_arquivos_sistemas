{"Guid":"cfc2d017-65a0-4dfd-adc2-646b62203979","Name":"List Itens Completo","Description":"List Itens Comp","SqlQuery":"/*\r\nRelatorio: List Itens Completo\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 20/09/2023\r\nATUALIZADO: 20/09/2023\r\n*/\r\nselect\r\nitems.id as 'ID Tabela',\r\nitems.KeyId as 'Codigo Item',\r\nitems.Description as 'Descrição',\r\nitems.ncmcode as 'NCM',\r\nitems.CestCode as 'CEST',\r\nitemstaxesbrasil.BenefCode as 'Beneficio Fiscal',\r\nt1.fulldescription as 'Sit Trib',\r\nitemstaxesbrasil.IcmsTax as 'Aliquota ICMS',\r\nitemstaxesbrasil.RedBCTax 'Red Base Calculo',\r\nitemstaxesbrasil.FcpTax 'FCP',\r\nitemstaxesbrasil.ICMSSTTax as 'Aliquota ICMS ST',\r\nitemstaxesbrasil.FcpSTTax as 'FCP ST',\r\nt3.fulldescription as 'CST PIS SAIDA',\r\nitemstaxesbrasil.PisOutTax as 'Aliquota CST PIS Saida',\r\nt2.fulldescription as 'CST COFINS SAIDA',\r\nitemstaxesbrasil.CofinsOutTax as 'Aliquota COFINS Saida',\r\n\r\nitems.cfop as 'CFOP'\r\n\r\nfrom items\r\nleft join (select * from fiscaltaxesbrazil where `type` in ('ICMS', 'CSOSN')) t1 on items.icmscode = t1.id\r\nleft join (select * from fiscaltaxesbrazil where `type` = 'COFINS') t2 on items.CofinsOutCode = t2.id\r\nleft join (select * from fiscaltaxesbrazil where `type` = 'PIS') t3 on items.PisOutCode = t3.id\r\nleft join (select * from fiscaltaxesbrazil where `type` = 'IPI') t4 on items.IpiCode = t4.id\r\ninner join itemstaxesbrasil on items.KeyId = itemstaxesbrasil.ItemKeyId\r\n/*\r\nRelatorio: List Itens Completo\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 20/09/2023\r\nATUALIZADO: 20/09/2023\r\n*/ @WHERE  @OTHERS ","SqlQueryWhere":"","SqlOtherClauses":"","Parameters":[],"Fields":[{"Name":"ID Tabela","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Codigo Item","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Descrição","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"NCM","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"CEST","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Beneficio Fiscal","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Sit Trib","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Aliquota ICMS","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Red Base Calculo","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"FCP","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Aliquota ICMS ST","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"FCP ST","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"CST PIS SAIDA","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Aliquota CST PIS Saida","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"CST COFINS SAIDA","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Aliquota COFINS Saida","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"CFOP","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true}],"IsPivot":false,"ExternalConnection":"","AddToRibbon":true,"ShowInPos":true}
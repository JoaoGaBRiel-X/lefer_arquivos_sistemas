{"Guid":"ec6c5509-ed63-46fc-8df3-3f42f21bd3dc","Name":"Comanda Aberta P/ Valor","Description":"C Aberta Valor","SqlQuery":"/*\r\nRelatorio: Comanda Aberta P/ Valor\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 06/06/2023\r\nATUALIZADO: 06/06/2023\r\n*/\r\nselect\r\nt1.Id as \"Comanda\",\r\ncase \r\nwhen t3.Name is not null then t3.Name\r\nelse 'Padrão'\r\nend as \"Tipo Comanda\",\r\ncase\r\nwhen t4.KeyId = t1.Id then 'BLOQUEADA'\r\nwhen t1.status = 1 then 'EM CONSUMO'\r\nwhen t1.status = 2 then 'PAGA'\r\nwhen t1.status = 3 then 'EM RECEBIMENTO'\r\nelse 'ATIVA'\r\nend as 'Status' ,\r\nround(t1.total, 2) as \"Valor\",\r\nCASE\r\nWHEN t2.Name IS NULL THEN 'SEM CLIENTE VINCULADO'\r\nELSE t2.Name\r\nEND as \"Cliente\",\r\nDATE_FORMAT(t1.SyncStamp, '%d/%m - %H:%i') as \"Ultima Movimentacao\",\r\ncase\r\nwhen t4.Description is not null then t4.Description\r\nelse ''\r\nend as 'Motivo'\r\nfrom xconfigsalezonesareaobjects t1\r\nleft join entities t2 on t1.CustomerKeyId = t2.KeyId\r\nleft join seriesdiscount t3 on t1.CardSerieId = t3.Id\r\nleft join lockedcards t4 on t1.Id = t4.KeyId\r\n/*\r\nRelatorio: Comanda Aberta P/ Valor\r\nAutor: João Gabriel Moraes Carvalho\r\nRevenda: Lefer Automação Comercial\r\nDATA: 06/06/2023\r\nATUALIZADO: 06/06/2023\r\n*/ @WHERE  @OTHERS ","SqlQueryWhere":"where t1.total >= @p_valor","SqlOtherClauses":"","Parameters":[{"Name":"@p_valor","Caption":"Valor maior que:","ParameterType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","DefaultValueType":0,"AvailableValueType":0,"AvailableValuesList":[]}],"Fields":[{"Name":"Comanda","FieldType":"System.Int32, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Tipo Comanda","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Status","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Valor","FieldType":"System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Cliente","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Ultima Movimentacao","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true},{"Name":"Motivo","FieldType":"System.String, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","Area":0,"IsVisible":true}],"IsPivot":false,"ExternalConnection":"","AddToRibbon":true,"ShowInPos":true}